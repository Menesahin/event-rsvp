# Docker Compose environment variables
# Copy this to .env.docker and adjust values

# PostgreSQL (used by postgres service + app)
POSTGRES_USER=event_rsvp
POSTGRES_PASSWORD=event_rsvp_dev_password
POSTGRES_DB=event_rsvp

# App database connection (inside docker network, uses service name)
DATABASE_URL=postgresql://event_rsvp:event_rsvp_dev_password@postgres:5432/event_rsvp

# Auth — REQUIRED, generate with: npx auth secret
AUTH_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG_SECRET
AUTH_RESEND_KEY=
AUTH_TRUST_HOST=true

# App mode
DEV_MODE=true
NODE_ENV=production
