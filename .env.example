# Database
# Local dev: postgresql://user:password@localhost:5432/event_rsvp
# Docker Compose: postgresql://event_rsvp:event_rsvp@postgres:5432/event_rsvp
DATABASE_URL="postgresql://user:password@localhost:5432/event_rsvp"

# Auth
AUTH_SECRET="" # Generate with: npx auth secret
AUTH_RESEND_KEY="" # Resend API key (production only)
AUTH_TRUST_HOST="true" # Required for Docker / non-localhost deployments

# App
DEV_MODE="true" # Show magic link directly (disable in production)
