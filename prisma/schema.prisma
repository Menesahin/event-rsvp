generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum UserRole {
  ADMIN
  ORGANIZER
  ATTENDEE
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  CANCELLED
}

enum RSVPStatus {
  GOING
  WAITLISTED
  CANCELLED
}

// ─── NextAuth.js v5 Models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(ATTENDEE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  organizedEvents Event[]   @relation("Organizer")
  rsvps           RSVP[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

model Event {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  date        DateTime
  endDate     DateTime?
  location    String
  coverImage  String?
  capacity    Int
  status      EventStatus @default(DRAFT)

  organizerId String
  organizer   User   @relation("Organizer", fields: [organizerId], references: [id])

  speakers Speaker[]
  rsvps    RSVP[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, date])
  @@index([organizerId])
  @@index([date])
}

model RSVP {
  id     String     @id @default(cuid())
  status RSVPStatus @default(GOING)

  userId  String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventId String
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([eventId, status])
  @@index([userId])
}

model Speaker {
  id     String  @id @default(cuid())
  name   String
  title  String?
  bio    String?
  avatar String?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}
